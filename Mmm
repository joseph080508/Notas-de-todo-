<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>SmartFit Landing</title>

<style>
body{
    margin:0;
    font-family: Arial, sans-serif;
    background:#f4f4f4;
}

/* HEADER */
header{
    background:#111;
    color:white;
    display:flex;
    justify-content:space-between;
    padding:15px 40px;
}

header nav a{
    color:white;
    margin-left:20px;
    text-decoration:none;
}

/* HERO */
.hero{
    background:url("https://images.unsplash.com/photo-1554284126-aa88f22d8b74") center/cover;
    color:white;
    text-align:center;
    padding:120px 20px;
}

.hero h1{
    font-size:40px;
}

.hero button{
    margin-top:20px;
    padding:10px 20px;
    border:none;
    background:#ffd700;
    cursor:pointer;
}

/* SECCIONES */
.section{
    display:flex;
    padding:40px;
    gap:30px;
}

.text{
    width:40%;
}

.images{
    width:60%;
}

.images img{
    width:100%;
    margin-bottom:10px;
    border-radius:10px;
}

/* GRID imágenes pequeñas */
.grid{
    display:flex;
    gap:10px;
}

.grid img{
    width:50%;
}

/* NORMAS */
.normas{
    text-align:center;
    padding:40px;
}

.cards{
    display:flex;
    flex-wrap:wrap;
    justify-content:center;
    gap:20px;
}

.card{
    background:#2ecc71;
    color:white;
    padding:20px;
    border-radius:20px;
    width:200px;
}

/* FOOTER */
footer{
    background:#111;
    color:white;
    text-align:center;
    padding:20px;
}
</style>
</head>

<body>

<header>
    <h2>SmartFit</h2>
    <nav>
        <a href="#">Clases</a>
        <a href="#">Planes</a>
        <a href="#">Sedes</a>
    </nav>
</header>

<section class="hero">
    <h1>Transforma tu cuerpo en Smart Fit</h1>
    <p>Entrena con equipos modernos y alcanza tu mejor versión</p>
    <button>Únete ahora</button>
</section>

<!-- SECCIÓN 1 -->
<section class="section">
    <div class="text">
        <h2>Entrenamiento Funcional</h2>
        <p>
        Mejora tu fuerza, resistencia y agilidad con rutinas dinámicas.
        Ideal para quemar grasa y tonificar el cuerpo.
        </p>
        <p><b>Horario:</b> 6:00 a.m - 9:00 p.m</p>
        <p><b>Sede:</b> Principal</p>
    </div>

    <div class="images">
        <img src="https://images.unsplash.com/photo-1599058917765-a780eda07a3e">
        <div class="grid">
            <img src="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b">
            <img src="https://images.unsplash.com/photo-1558611848-73f7eb4001a1">
        </div>
    </div>
</section>

<!-- SECCIÓN 2 -->
<section class="section">
    <div class="text">
        <h2>Zona de Pesas</h2>
        <p>
        Equipos modernos para trabajar todos los grupos musculares
        con seguridad y eficiencia.
        </p>
        <p><b>Horario:</b> 24 horas</p>
        <p><b>Sede:</b> Todas</p>
    </div>

    <div class="images">
        <img src="https://images.unsplash.com/photo-1581009146145-b5ef050c2e1e">
        <div class="grid">
            <img src="https://images.unsplash.com/photo-1598971639058-999b7c91e39a">
            <img src="https://images.unsplash.com/photo-1605296867424-35fc25c9212a">
        </div>
    </div>
</section>

<!-- NORMAS -->
<section class="normas">
    <h2>Normas del Gimnasio</h2>

    <div class="cards">
        <div class="card">Usar toalla</div>
        <div class="card">No dejar pesas tiradas</div>
        <div class="card">Limpiar máquinas</div>
        <div class="card">Respetar turnos</div>
        <div class="card">Usar ropa adecuada</div>
        <div class="card">No hacer ruido excesivo</div>
    </div>
</section>

<footer>
    <p>© 2026 SmartFit - Todos los derechos reservados</p>
</footer>

</body>
</html>
